{
  "schemaVersion": "0.1.0",
  "suite": "intentbench-evolve-model-trajectory-smoke",
  "description": "A candidate-free trajectory manifest for external model adapters.",
  "conditions": ["intent-patch"],
  "applications": [
    {
      "id": "work-item",
      "baseSource": "tasks/work_item/base.intent",
      "checkpoints": [
        {
          "id": "add-priority",
          "checkpoint": 1,
          "instruction": "Add an Integer priority field to WorkItem with a default value of 0.",
          "hiddenTests": "tasks/work_item/checkpoint_01.hidden.intent",
          "expectedChangedSymbols": ["entity:WorkItem"]
        },
        {
          "id": "add-owner",
          "checkpoint": 2,
          "instruction": "Add a Text owner field to WorkItem with a default value of unassigned.",
          "hiddenTests": "tasks/work_item/checkpoint_02.hidden.intent",
          "expectedChangedSymbols": ["entity:WorkItem"]
        },
        {
          "id": "add-archive-state",
          "checkpoint": 3,
          "instruction": "Add a Boolean archived field to WorkItem with a default value of false.",
          "hiddenTests": "tasks/work_item/checkpoint_03.hidden.intent",
          "expectedChangedSymbols": ["entity:WorkItem"]
        },
        {
          "id": "add-archive-action",
          "checkpoint": 4,
          "instruction": "Add an ArchiveWorkItem action that selects by id and sets archived to true.",
          "hiddenTests": "tasks/work_item/checkpoint_04.hidden.intent",
          "expectedChangedSymbols": ["action:ArchiveWorkItem"]
        }
      ]
    }
  ]
}
