{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentir.dev/schemas/intentbench-evolve/manifest-0.1.0.json",
  "title": "IntentBench-Evolve Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "conditions", "tasks"],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "full-file",
          "unified-diff",
          "structure-edit",
          "intent-patch"
        ]
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "fileReference": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "application",
        "checkpoint",
        "instruction",
        "baseSource",
        "hiddenTests",
        "expectedChangedSymbols",
        "candidates"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "application": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint": {
          "type": "integer",
          "minimum": 1
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "baseSource": {
          "$ref": "#/$defs/fileReference"
        },
        "hiddenTests": {
          "$ref": "#/$defs/fileReference"
        },
        "expectedChangedSymbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidates": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "full-file": {
              "$ref": "#/$defs/fileReference"
            },
            "unified-diff": {
              "$ref": "#/$defs/fileReference"
            },
            "structure-edit": {
              "$ref": "#/$defs/fileReference"
            },
            "intent-patch": {
              "$ref": "#/$defs/fileReference"
            }
          }
        }
      }
    }
  }
}
