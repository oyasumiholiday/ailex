{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oyasumiholiday/ailex/benchmarks/intentbench_evolve/schema/pilot_protocol.schema.json",
  "title": "IntentBench-Evolve paid pilot protocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "manifest",
    "conditions",
    "provider",
    "model",
    "reasoningEffort",
    "maxOutputTokens",
    "requestTimeoutSeconds",
    "trials",
    "budgetUsd",
    "maxRequestBytesPerCall",
    "reservedInputTokensPerCall",
    "pricing"
  ],
  "properties": {
    "schemaVersion": {"const": "0.1.0"},
    "id": {"type": "string", "minLength": 1},
    "manifest": {"type": "string", "minLength": 1},
    "conditions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["full-file", "unified-diff", "structure-edit", "intent-patch"]
      }
    },
    "provider": {"const": "openai-responses"},
    "model": {
      "type": "string",
      "pattern": ".*-\\d{4}-\\d{2}-\\d{2}$"
    },
    "reasoningEffort": {
      "enum": ["none", "low", "medium", "high", "xhigh"]
    },
    "maxOutputTokens": {"type": "integer", "minimum": 1, "maximum": 200000},
    "requestTimeoutSeconds": {"type": "integer", "minimum": 1, "maximum": 600},
    "trials": {"type": "integer", "minimum": 1, "maximum": 20},
    "budgetUsd": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$"},
    "maxRequestBytesPerCall": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4000000
    },
    "reservedInputTokensPerCall": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "inputPerMillionTokens",
        "outputPerMillionTokens",
        "observedAt",
        "sourceUrl"
      ],
      "properties": {
        "currency": {"const": "USD"},
        "inputPerMillionTokens": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+)?$"
        },
        "outputPerMillionTokens": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+)?$"
        },
        "observedAt": {"type": "string", "format": "date"},
        "sourceUrl": {
          "type": "string",
          "pattern": "^https://developers\\.openai\\.com/"
        }
      }
    }
  }
}
